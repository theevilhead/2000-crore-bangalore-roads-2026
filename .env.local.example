# Mapbox public token (GL JS, Directions, Static Images). Restrict by URL in the Mapbox dashboard.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Supabase project (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Turnstile captcha (OPTIONAL). Set BOTH to enable captcha on report
# submission; leave both blank to disable (e.g. for local dev).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
